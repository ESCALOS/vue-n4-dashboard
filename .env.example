# ==============================
# Vue N4 Dashboard - .env.example
# Copia este archivo a .env y ajusta valores reales.
# ==============================

# URL base de API en el navegador.
# Recomendado en producción: /api (mismo origen, evita mixed content)
VITE_API_URL=/api

# Upstream del proxy nginx (frontend server -> backend server TLS sidecar)
# Producción actual backend: 10.20.13.13 (TLS interno en 3443)
BACKEND_UPSTREAM=https://10.20.13.13:3443

# Modo del WAF (OWASP CRS)
# DetectionOnly para fase de tuning, On para bloqueo
MODSEC_RULE_ENGINE=DetectionOnly

# Nivel de paranoia de CRS (1 recomendado para iniciar)
PARANOIA=1